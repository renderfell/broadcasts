{
  "name": "Broadcasts",
  "description": "Watch multiple broadcasts in a customizable grid.",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://renderfell.github.io/broadcasts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist --nojekyll -m \"chore: deploy to github pages on $(date '+%Y-%m-%d %H:%M')\"",
    "release": "semantic-release",
    "lint": "eslint .",
    "format": "prettier . --write",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html,md}": "prettier --write"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "vite": "^6.3.5"
  }
}
